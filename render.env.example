# JanSetu API — Render Production Environment
# Copy to render.env, fill in real values, upload via Render "Add from .env"
# NEVER commit the filled-in render.env to git (it's in .gitignore)

ENVIRONMENT=production
PYTHON_VERSION=3.12.0

# ── DATABASE ─────────────────────────────────────────────────────────────────
# CRITICAL: Use session-mode pooler (port 5432), NOT 6543 (transaction mode breaks asyncpg)
# CRITICAL: Use aws-1 host, not aws-0 (project is on aws-1 cluster)
# Get from: Supabase Dashboard → Settings → Database → URI → change port to 5432
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ── REDIS ────────────────────────────────────────────────────────────────────
# From Upstash dashboard → Redis → Details → REDIS_URL
REDIS_URL=rediss://default:PASSWORD@HOSTNAME.upstash.io:6379

# ── SUPABASE ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ── JWT ──────────────────────────────────────────────────────────────────────
# Production uses Supabase ES256 JWT (this is dev-only fallback)
JWT_SECRET=generate-with-python3-c-import-secrets-print-secrets.token_hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── STORAGE ──────────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=https://PROJECT_REF.supabase.co/storage/v1/s3
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_MEDIA=dcos-media
STORAGE_REGION=ap-south-1

# ── AI (GROQ) ────────────────────────────────────────────────────────────────
# Primary AI provider — free at console.groq.com
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── WHATSAPP ─────────────────────────────────────────────────────────────────
# From Meta for Developers → Your App → WhatsApp → API Setup
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_TOKEN=your-whatsapp-token-60-day-expiry
WHATSAPP_PHONE_NUMBER_ID=your-15-digit-phone-number-id
WHATSAPP_VERIFY_TOKEN=dcos-whatsapp-verify

# Webhook URL to configure in Meta dashboard:
# https://dcos.onrender.com/api/v1/intake/webhooks/whatsapp
# Subscribe to: messages

# ── NOTIFICATIONS (OPTIONAL) ──────────────────────────────────────────────────
# SMS via MSG91 — leave empty to disable SMS fallback
MSG91_API_KEY=
MSG91_SENDER_ID=DCOSGOV
MSG91_TEMPLATE_ID_STATUS=

# ── CORS ─────────────────────────────────────────────────────────────────────
# MUST be a JSON array (pydantic-settings v2 requires this format)
# With the Vercel proxy in next.config.ts, CORS is not strictly needed
# but keep it set for direct API testing tools
CORS_ORIGINS=["https://dcos-ecru.vercel.app","http://localhost:3000"]

# ── FEATURE FLAGS ────────────────────────────────────────────────────────────
FEATURE_AI_CLASSIFY=true
FEATURE_WHATSAPP_INTAKE=true
FEATURE_ANALYTICS_NL_QUERY=true
FEATURE_CHATBOT=true
FEATURE_VOICE_INTAKE=false

# ── OBSERVABILITY (OPTIONAL) ──────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=jansetu-api
