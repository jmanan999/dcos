# DCOS API — Render Production Environment
# Copy this file to render.env, fill in real values, upload via Render "Add from .env"
# NEVER commit the filled-in render.env to git

ENVIRONMENT=production
PYTHON_VERSION=3.12.0

# Database — Supabase session-mode pooler (port 5432, supports prepared statements)
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?ssl=require

# Redis — Upstash (copy from Upstash dashboard, starts with rediss://)
REDIS_URL=rediss://default:PASSWORD@HOSTNAME.upstash.io:6379

# Supabase
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# JWT (production uses Supabase ES256 — this is the fallback for local dev tokens)
JWT_SECRET=generate-with-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Object storage
STORAGE_ENDPOINT=https://PROJECT_REF.supabase.co/storage/v1/s3
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_MEDIA=dcos-media
STORAGE_REGION=ap-south-1

# AI — Groq (primary, free at console.groq.com)
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Gemini (fallback)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL_DEFAULT=gemini-2.5-flash

# OpenRouter (fallback)
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# WhatsApp — Meta Developer Console
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=jansetu-whatsapp-verify

# SMS — MSG91
MSG91_API_KEY=
MSG91_SENDER_ID=DCOSGOV
MSG91_TEMPLATE_ID_STATUS=

# Web Push — generate with: python3 -c "from cryptography.hazmat.primitives.asymmetric import ec; from cryptography.hazmat.primitives import serialization; import base64; k=ec.generate_private_key(ec.SECP256R1()); print(base64.urlsafe_b64encode(k.private_numbers().private_value.to_bytes(32,'big')).decode().rstrip('='), base64.urlsafe_b64encode(k.public_key().public_bytes(serialization.Encoding.X962,serialization.PublicFormat.UncompressedPoint)).decode().rstrip('='))"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@dcos.delhi.gov.in

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=dcos-api

# CORS — your Vercel production URL
CORS_ORIGINS=["https://dcos-delhi.vercel.app"]

# Feature flags
FEATURE_AI_CLASSIFY=true
FEATURE_WHATSAPP_INTAKE=false
FEATURE_ANALYTICS_NL_QUERY=true
